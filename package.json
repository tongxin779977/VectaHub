{
  "name": "vectahub",
  "version": "1.0.1",
  "type": "module",
  "description": "VectaHub - Natural Language Workflow Engine",
  "main": "dist/index.js",
  "bin": {
    "vectahub": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "build:watch": "tsup src/cli.ts --format esm --watch",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest --run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["workflow", "automation", "cli", "llm", "ai"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "lodash": "^4.18.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=21.0.0"
  },
  "files": [
    "dist"
  ]
}
