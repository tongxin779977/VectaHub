{
  "name": "vectahub",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "description": "VectaHub - Natural Language Workflow Engine",
  "main": "dist/index.js",
  "bin": {
    "vectahub": "dist/cli.js"
  },
  "scripts": {
    "build:cli": "tsup src/cli.ts --format esm,cjs --dts",
    "dev:cli": "tsx src/cli.ts",
