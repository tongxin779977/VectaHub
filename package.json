    "typecheck": "tsc --noEmit",
    "vectahub": "tsx src/cli.ts"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
